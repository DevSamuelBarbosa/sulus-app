APP_NAME="Sulus Benefícios"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker: use the "postgres" service host. Local host w/o Docker: use sqlite.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sulus
DB_USERNAME=sulus
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# QR tokens and cache live in Redis.
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Docker dev catches mail with Mailpit — read it at http://localhost:8025.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Media storage (employee photos, company/establishment logos) — Cloudflare
# R2, private bucket + signed URLs. Set MEDIA_DISK=r2 (and FILESYSTEM_DISK=r2)
# in production; local dev uses "public". Package + config are already ready
# (see config/filesystems.php) — once the bucket exists, just fill in the
# R2_* values below and flip MEDIA_DISK/FILESYSTEM_DISK to "r2".
MEDIA_DISK=public
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
# Optional public/custom-domain base URL (leave empty to use signed URLs only).
R2_URL=
R2_USE_PATH_STYLE_ENDPOINT=true

# Temporary QR token (seconds)
QRCODE_TTL=180
QRCODE_CONFIRMATION_TTL=120

# Sanctum / SPA
SANCTUM_STATEFUL_DOMAINS=localhost:5173
FRONTEND_URL=http://localhost:5173

VITE_APP_NAME="${APP_NAME}"
